package com.kodewala.app;

import org.springframework.context.ApplicationContext;
import org.springframework.context.annotation.AnnotationConfigApplicationContext;
import org.springframework.context.support.AbstractApplicationContext;

import com.kodewala.app.bean.AccountMngm;
import com.kodewala.config.SpringConfig;

public class Application {
	public static void main(String[] args) {
		
		ApplicationContext context = new AnnotationConfigApplicationContext(SpringConfig.class);
		
		AccountMngm accountMngmv = 	context.getBean(AccountMngm.class);
		
		accountMngmv.printDetails();
		 ((AbstractApplicationContext) context).close();   // close the ioc container
	}

}
