<!DOCTYPE html>
<html>
<head>
<meta charset="ISO-8859-1">
<title>Rapido sign-Up</title>
</head>
<body>


	<form action="signup" method="post">

		<!-- Mobile -->
		<label>Mobile Number:</label><br> <input type="text"
			name="mobile" placeholder="Enter mobile number" required><br>
		<br>

		<!-- Email -->
		<label>Email:</label><br> <input type="email" name="email"
			placeholder="Enter email" required><br>
		<br>

		<!-- Location -->
		<label>Location:</label><br> <input type="text" name="location"
			placeholder="Enter location" required><br>
		<br>

		<!-- OTP -->
		<label>OTP:</label><br> <input type="text" name="otp"
			placeholder="Enter OTP" required><br>
		<br>

		<!-- Buttons -->
		<button type="button">Send OTP</button>
		<button type="submit">Register</button>

	</form>


